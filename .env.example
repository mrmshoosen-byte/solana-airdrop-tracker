# ===================================
# SOLANA AIRDROP TRACKER
# Environment Variables Configuration
# ===================================

# Database Configuration
# For local development with Docker Compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/airdrop_tracker

# For Vercel Postgres (recommended for production)
# DATABASE_URL=postgresql://...your-vercel-postgres-url...

# Helius API Configuration
# Get your free API key from: https://dev.helius.xyz
HELIUS_API_KEY=your_helius_api_key_here

# Solana Token Configuration
# The token mint address to track
# Example: 9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump
TOKEN_MINT=9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump

# Next.js Configuration
NODE_ENV=development
# or NODE_ENV=production for Vercel

# Sync Configuration (Optional)
# Maximum number of wallet behaviors to sync per run
SYNC_BATCH_SIZE=100

# Caching (Optional)
# Cache duration in minutes
CACHE_DURATION=60
